# Build rule for target.
repetition_detection_demo: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 repetition_detection_demo
.PHONY : repetition_detection_demo

# fast build rule for target.
repetition_detection_demo/fast:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/repetition_detection_demo.dir/build.make CMakeFiles/repetition_detection_demo.dir/build
.PHONY : repetition_detection_demo/fast

