# Fastchess gauntlet artifacts
*.pgn
fastchess.log
config.json

# ...except gauntlet/ results, which are git-shuttled between the
# AMD and Intel boxes (BACKLOG #19). Scoped negation keeps scratch
# PGNs/logs in the fastchess folder ignored.
!gauntlet/*.pgn
!gauntlet/*.log

# Claude Code local agent state (per-project permission cache).
# Track .claude/settings.json (shared project-level allowlist) but not
# .claude/settings.local.json (per-machine).
.claude/*
!.claude/settings.json
test/__pycache__/

# WAC tactical-suite test artifacts (logs are large and timestamped per run;
# the durable results are extracted into docs/SEARCH_AND_EVAL.md when they
# matter). Already-tracked 2025-09-11 logs stay tracked as a historical
# baseline that's harder to reproduce.
test/wac_test_log_*.txt
test/wac_failed_positions_*.txt
test/wac_retest_*.txt
# WAC-201 reduced-suite artifacts (wac201_test.py) — same policy.
test/wac201_test_log_*.txt
test/wac201_failed_positions_*.txt
test/wac201_retest_*.txt

# Texel tuner (#9) extracted training corpora — large and regenerable from PGNs.
tools/texel/fens*.txt
# Large raw training datasets dropped into test/ (Zurichess EPD, game dumps).
test/quiet-labeled.epd.txt
test/*.epd.txt
# Played-game calibration output (#41) — large, regenerable via run_cc_analysis.bat.
tools/cc_analysis*.csv
